#!/usr/bin/env python
# vim:fileencoding=utf-8

import json
import re
import time
from urllib.parse import urlencode, quote
from datetime import datetime, timedelta

from calibre.web.feeds.news import BasicNewsRecipe
from calibre import browser
from mechanize import Request

# ===== 自定义 User-Agent，模拟真实浏览器 =====
USER_AGENT = 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/146.0.0.0 Safari/537.36'

def safe_dict(data, *names):
    ans = data
    for x in names:
        ans = ans.get(x) or {}
    return ans

def process_url(url):
    if url.startswith('/'):
        url = 'https://www.economist.com' + url
    return url

class Economist(BasicNewsRecipe):
    title = 'The Economist'
    language = 'en_GB'
    encoding = 'utf-8'
    __author__ = 'Custom'
    description = 'The Economist - Custom recipe with updated browser'

    delay = 1
    browser_type = 'webengine'
    no_stylesheets = True
    remove_attributes = ['style', 'height', 'width']
    resolve_internal_links = True

    recipe_specific_options = {
        'date': {
            'short': 'The date of the edition to download (YYYY-MM-DD format)',
            'long': 'For example, 2024-07-19',
        },
        'res': {
            'short': 'For hi-res images',
            'long': 'default: 600',
            'default': '600',
        },
    }

    extra_css = '''
        em { color:#202020; }
        img {display:block; margin:0 auto;}
    '''

    def get_browser(self, *args, **kwargs):
        """强制使用真实浏览器 User-Agent，并添加 Cookie"""
        kwargs['user_agent'] = USER_AGENT
        br = BasicNewsRecipe.get_browser(self, *args, **kwargs)
        # 添加模拟 Cookie，尝试绕过 Cloudflare
        br.addheaders.append(('Cookie', 'cookies_enabled=true;'))
        return br

    def parse_index(self):
        """解析周刊索引"""
        edition_date = self.recipe_specific_options.get('date')
        if edition_date and isinstance(edition_date, str):
            url = 'https://www.economist.com/weeklyedition/' + edition_date
            self.timefmt = ' [' + edition_date + ']'
        else:
            url = 'https://www.economist.com/weeklyedition'

        self.log('Fetching from: ' + url)

        # 使用自定义浏览器打开
        br = self.get_browser()
        try:
            response = br.open(url)
            raw_html = response.read().decode('utf-8')
            soup = self.index_to_soup(raw_html)
        except Exception as e:
            self.log('Error fetching page: ' + str(e))
            # 如果失败，尝试使用默认方法
            soup = self.index_to_soup(url)

        # 尝试从 __NEXT_DATA__ 中解析
        script_tag = soup.find('script', id='__NEXT_DATA__')
        if script_tag is None:
            self.log('No __NEXT_DATA__ found, trying fallback...')
            # 如果找不到，尝试使用 GraphQL API
            return self.parse_index_via_graphql()

        try:
            data = json.loads(script_tag.string)
        except Exception as e:
            self.log('Failed to parse __NEXT_DATA__: ' + str(e))
            return self.parse_index_via_graphql()

        feeds = []
        seen = set()

        self.cover_url = safe_dict(data, 'props', 'pageProps', 'content', 'cover', 'url')
        if self.cover_url:
            self.cover_url = self.cover_url.replace(
                'economist.com/',
                'economist.com/cdn-cgi/image/width=960,quality=80,format=auto/'
            )

        for component in safe_dict(data, 'props', 'pageProps', 'content', 'components'):
            if component.get('type') == 'AD':
                continue
            if component.get('type') == 'COLLECTION':
                section = component.get('name', 'Articles')
                articles = []
                for article in component.get('articles', []):
                    if article.get('id') in seen:
                        continue
                    seen.add(article.get('id'))
                    title = article.get('headline', '')
                    url = process_url(article.get('url', ''))
                    desc = article.get('rubric', '')
                    self.log('\t', title, '\n\t', desc, '\n\t\t', url)
                    articles.append({'title': title, 'url': url, 'description': desc})
                if articles:
                    feeds.append((section, articles))

        if not feeds:
            self.log('No articles found from __NEXT_DATA__, trying GraphQL...')
            return self.parse_index_via_graphql()

        return feeds

    def parse_index_via_graphql(self):
        """备用方法：使用 GraphQL API 获取文章列表"""
        self.log('Attempting to fetch via GraphQL...')

        # 构建 GraphQL 查询
        query = {
            'operationName': 'WeeklyEditionQuery',
            'variables': '{"editionDate":"' + self.recipe_specific_options.get('date', '') + '"}',
            'query': 'query WeeklyEditionQuery($editionDate: String) { weeklyEdition(date: $editionDate) { headline formattedIssueDate cover { url } components { __typename type name articles { id headline url rubric flyTitle } } } }'
        }

        url = 'https://cp2-graphql-gateway.p.aws.economist.com/graphql?' + urlencode(
            query, safe='()!', quote_via=quote
        )

        br = self.get_browser()
        br.addheaders.append(('Content-Type', 'application/json'))

        try:
            response = br.open(url)
            raw = response.read().decode('utf-8')
            data = json.loads(raw)

            # 解析 GraphQL 响应
            edition = data.get('data', {}).get('weeklyEdition', {})
            if not edition:
                raise Exception('No edition data')

            self.cover_url = edition.get('cover', {}).get('url', '')
            if self.cover_url:
                self.cover_url = self.cover_url.replace(
                    'economist.com/',
                    'economist.com/cdn-cgi/image/width=960,quality=80,format=auto/'
                )

            feeds = []
            seen = set()

            for component in edition.get('components', []):
                if component.get('__typename') == 'AdComponent':
                    continue
                section = component.get('name', 'Articles')
                articles = []
                for article in component.get('articles', []):
                    if article.get('id') in seen:
                        continue
                    seen.add(article.get('id'))
                    title = article.get('headline', '')
                    url = process_url(article.get('url', ''))
                    desc = article.get('rubric', '')
                    self.log('\t', title, '\n\t', desc, '\n\t\t', url)
                    articles.append({'title': title, 'url': url, 'description': desc})
                if articles:
                    feeds.append((section, articles))

            if feeds:
                return feeds

        except Exception as e:
            self.log('GraphQL fetch failed: ' + str(e))

        # 如果所有方法都失败，返回错误
        self.log('All methods failed to find articles.')
        return []

    def preprocess_html(self, soup):
        """处理图片分辨率"""
        width = '600'
        w = self.recipe_specific_options.get('res')
        if w and isinstance(w, str):
            width = w
        for img in soup.findAll('img', src=True):
            if 'economist.com' in img['src']:
                img['src'] = img['src'].replace(
                    'economist.com/',
                    'economist.com/cdn-cgi/image/width=' + width + ',quality=80,format=auto/'
                )
        return soup
